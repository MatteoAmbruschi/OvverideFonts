{
    "manifest_version": 3,
    "name": "Font Override",
    "version": "1.0.0",
    "description": "System-wide font override for all web pages",
    "permissions": [
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:59842/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start",
            "all_frames": true
        }
    ]
}